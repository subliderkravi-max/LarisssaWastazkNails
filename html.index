<!DOCTYPE html>
<html lang="pt-BR">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Larissa Waszak | Nail Designer</title>
<meta name="description" content="Larissa Waszak, Nail Designer. Unhas tradicionais, esmaltação em gel e banho de gel. Agende pelo WhatsApp.">
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@600;700&family=Poppins:wght@400;500;600;700&family=Dancing+Script:wght@600;700&display=swap" rel="stylesheet">
<style>
/* =========================================================
   Larissa Waszak — Nail Designer
   Tokens
========================================================= */
:root{
  --ivory: #FFF6F8;
  --blush: #FBD9E6;
  --rose: #E8527A;
  --rose-deep: #C23862;
  --gold: #C9A24B;
  --plum: #3A222B;
  --white: #FFFFFF;
  --whatsapp: #25D366;

  --font-display: 'Playfair Display', serif;
  --font-body: 'Poppins', sans-serif;
  --font-script: 'Dancing Script', cursive;

  --radius: 18px;
  --shadow-soft: 0 10px 30px rgba(194, 56, 98, 0.18);
}

*{ box-sizing: border-box; }
html{ scroll-behavior: smooth; }

body{
  margin: 0;
  font-family: var(--font-body);
  color: var(--plum);
  background: var(--ivory);
  -webkit-font-smoothing: antialiased;
}

img{ max-width: 100%; display: block; }

a{ color: inherit; text-decoration: none; }

strong, b{ font-weight: 700; color: var(--rose-deep); }

.container{
  max-width: 1080px;
  margin: 0 auto;
  padding: 0 1.5rem;
}

/* =========================================================
   Brush-stroke signature underline
========================================================= */
.brush-underline{
  display: block;
  width: 140px;
  height: 18px;
  margin: 0.4rem auto 0;
}
.brush-underline path{
  stroke: var(--gold);
  stroke-width: 4;
  fill: none;
  stroke-linecap: round;
}
.brush-underline.light path{ stroke: var(--blush); }

/* =========================================================
   Header
========================================================= */
.site-header{
  position: relative;
  text-align: center;
  padding: 1.4rem 1rem 1.2rem;
  background: var(--white);
  border-bottom: 1px solid var(--blush);
}
.site-header .logo{
  font-family: var(--font-display);
  font-size: 1.5rem;
  font-weight: 700;
  color: var(--rose-deep);
  letter-spacing: 0.5px;
}
.site-header .logo span{
  display: block;
  font-family: var(--font-body);
  font-size: 0.7rem;
  letter-spacing: 3px;
  text-transform: uppercase;
  color: var(--gold);
  font-weight: 600;
  margin-top: 2px;
}
.header-link{
  position: absolute;
  top: 50%;
  left: 1.5rem;
  transform: translateY(-50%);
  font-size: 0.85rem;
  font-weight: 700;
  color: var(--rose-deep);
  display: flex;
  align-items: center;
  gap: 6px;
}
.header-link:hover{ color: var(--rose); }

/* =========================================================
   Hero
========================================================= */
.hero{
  position: relative;
  overflow: hidden;
  text-align: center;
  padding: 4.5rem 1.5rem 5rem;
  background: linear-gradient(160deg, var(--rose) 0%, var(--rose-deep) 55%, #9c2c4f 100%);
  color: var(--white);
}
.hero::before, .hero::after{
  content: "";
  position: absolute;
  border-radius: 50%;
  filter: blur(40px);
  opacity: 0.35;
}
.hero::before{
  width: 260px; height: 260px;
  background: var(--blush);
  top: -80px; left: -60px;
  animation: float-blob 9s ease-in-out infinite;
}
.hero::after{
  width: 220px; height: 220px;
  background: var(--gold);
  bottom: -70px; right: -50px;
  animation: float-blob 11s ease-in-out infinite reverse;
}
@keyframes float-blob{
  0%, 100%{ transform: translate(0,0); }
  50%{ transform: translate(20px, -15px); }
}
.hero-content{ position: relative; z-index: 2; }
.eyebrow-badge{
  display: inline-block;
  background: rgba(255,255,255,0.16);
  border: 1px solid rgba(255,255,255,0.45);
  color: var(--white);
  font-size: 0.7rem;
  letter-spacing: 3px;
  text-transform: uppercase;
  font-weight: 700;
  padding: 6px 18px;
  border-radius: 999px;
  margin-bottom: 1rem;
}
.hero h1{
  font-family: var(--font-display);
  font-size: clamp(2.2rem, 6vw, 3.4rem);
  margin: 0.2rem 0 0.6rem;
  font-weight: 700;
}
.hero p.tagline{
  font-size: 1.05rem;
  max-width: 480px;
  margin: 0 auto;
  line-height: 1.6;
}
.hero p.tagline strong{ color: var(--white); border-bottom: 2px solid var(--gold); }

.btn-primary{
  display: inline-flex;
  align-items: center;
  gap: 10px;
  margin-top: 2rem;
  background: var(--white);
  color: var(--rose-deep);
  font-weight: 700;
  font-size: 0.95rem;
  padding: 14px 28px;
  border-radius: 999px;
  box-shadow: var(--shadow-soft);
  transition: transform 0.2s ease, box-shadow 0.2s ease;
}
.btn-primary:hover{ transform: translateY(-3px); box-shadow: 0 14px 30px rgba(0,0,0,0.22); }
.btn-primary svg{ width: 20px; height: 20px; }

/* =========================================================
   Intro
========================================================= */
.intro{
  text-align: center;
  padding: 3.5rem 1.5rem 1rem;
}
.intro p{
  max-width: 620px;
  margin: 0 auto;
  font-size: 1.05rem;
  line-height: 1.75;
  color: var(--plum);
}

/* =========================================================
   Section heading pattern (eyebrow pill + title + brush)
========================================================= */
.section-heading{
  text-align: center;
  margin-bottom: 2.2rem;
}
.section-heading .pill{
  display: inline-block;
  background: var(--rose);
  color: var(--white);
  font-family: var(--font-display);
  font-weight: 700;
  font-size: 1rem;
  letter-spacing: 1px;
  padding: 8px 26px;
  border-radius: 999px;
  box-shadow: var(--shadow-soft);
}
.section-heading h2{
  font-family: var(--font-display);
  font-size: clamp(1.6rem, 4vw, 2.2rem);
  margin: 0.8rem 0 0;
  color: var(--plum);
}

/* =========================================================
   Pricing
========================================================= */
.pricing{
  padding: 1rem 1.5rem 4rem;
}
.price-card{
  max-width: 640px;
  margin: 0 auto;
  background: linear-gradient(165deg, var(--rose-deep), var(--rose) 70%);
  color: var(--white);
  border-radius: var(--radius);
  padding: 2.2rem 1.8rem 2.6rem;
  box-shadow: var(--shadow-soft);
}
.price-row{
  display: flex;
  justify-content: space-between;
  align-items: baseline;
  gap: 1rem;
  padding: 0.85rem 0;
  border-bottom: 1px solid rgba(255,255,255,0.3);
}
.price-row:last-child{ border-bottom: none; }
.price-row .service{
  font-weight: 700;
  font-size: 0.98rem;
  line-height: 1.3;
}
.price-row .value{
  font-weight: 700;
  white-space: nowrap;
  font-size: 0.98rem;
  font-family: var(--font-body);
}
.price-quote{
  font-family: var(--font-script);
  text-align: center;
  font-size: 1.5rem;
  color: var(--plum);
  margin: 2.6rem auto 0.4rem;
  max-width: 520px;
}
.price-signature{
  text-align: center;
  font-family: var(--font-script);
  font-size: 1.6rem;
  color: var(--rose-deep);
  margin: 0;
}
.price-signature span{
  display: block;
  font-family: var(--font-body);
  font-size: 0.72rem;
  letter-spacing: 2px;
  text-transform: uppercase;
  color: var(--gold);
  font-weight: 700;
  margin-top: 2px;
}

/* =========================================================
   Final CTA
========================================================= */
.final-cta{
  text-align: center;
  background: var(--blush);
  padding: 3.5rem 1.5rem;
}
.final-cta h2{
  font-family: var(--font-display);
  font-size: clamp(1.5rem, 4vw, 2rem);
  margin-bottom: 0.6rem;
}
.final-cta p{
  max-width: 460px;
  margin: 0 auto 1.6rem;
  line-height: 1.7;
}
.final-cta .phone{
  display: inline-block;
  font-weight: 700;
  color: var(--rose-deep);
  background: var(--white);
  padding: 6px 16px;
  border-radius: 999px;
  margin-bottom: 1.4rem;
  box-shadow: 0 4px 10px rgba(0,0,0,0.08);
}
.btn-whatsapp-inline{
  display: inline-flex;
  align-items: center;
  gap: 10px;
  background: var(--whatsapp);
  color: var(--white);
  font-weight: 700;
  padding: 14px 30px;
  border-radius: 999px;
  box-shadow: 0 10px 24px rgba(37, 211, 102, 0.4);
  transition: transform 0.2s ease;
}
.btn-whatsapp-inline:hover{ transform: translateY(-3px); }
.btn-whatsapp-inline svg{ width: 20px; height: 20px; }

/* =========================================================
   Trabalhos grid (no real photos — icon cards)
========================================================= */
.trabalhos-grid{
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
  gap: 1.4rem;
  max-width: 980px;
  margin: 0 auto;
}
.work-card{
  background: var(--white);
  border: 1px solid var(--blush);
  border-radius: var(--radius);
  padding: 1.8rem 1.4rem;
  text-align: center;
  box-shadow: 0 6px 18px rgba(194,56,98,0.08);
  transition: transform 0.25s ease, box-shadow 0.25s ease;
}
.work-card:hover{
  transform: translateY(-5px);
  box-shadow: var(--shadow-soft);
}
.work-card .icon{
  width: 52px; height: 52px;
  margin: 0 auto 1rem;
  color: var(--rose);
}
.work-card h3{
  font-family: var(--font-display);
  font-size: 1.05rem;
  margin: 0 0 0.4rem;
  color: var(--plum);
}
.work-card p{
  font-size: 0.88rem;
  color: #6b5560;
  line-height: 1.5;
  margin: 0;
}

.work-note{
  max-width: 600px;
  margin: 0 auto 2.6rem;
  text-align: center;
  background: var(--white);
  border: 1px dashed var(--gold);
  border-radius: var(--radius);
  padding: 1.1rem 1.4rem;
  font-size: 0.9rem;
  color: var(--plum);
}

/* =========================================================
   Floating WhatsApp button
========================================================= */
.whatsapp-float{
  position: fixed;
  bottom: 22px;
  right: 22px;
  z-index: 50;
  display: flex;
  align-items: center;
  background: var(--whatsapp);
  color: var(--white);
  width: 58px;
  height: 58px;
  border-radius: 50%;
  justify-content: center;
  box-shadow: 0 8px 20px rgba(0,0,0,0.28);
  transition: width 0.3s ease, border-radius 0.3s ease, transform 0.2s ease;
  overflow: hidden;
  white-space: nowrap;
}
.whatsapp-float svg{ width: 28px; height: 28px; flex-shrink: 0; }
.whatsapp-float span{
  font-weight: 700;
  font-size: 0.9rem;
  margin-left: 10px;
  opacity: 0;
  max-width: 0;
  transition: opacity 0.2s ease;
}
.whatsapp-float:hover{
  width: 200px;
  border-radius: 30px;
  padding: 0 18px;
  transform: translateY(-2px);
}
.whatsapp-float:hover span{ opacity: 1; max-width: 140px; }

/* =========================================================
   Floating side tab (ribbon) — navigates to a new page
========================================================= */
.side-tab{
  position: fixed;
  top: 50%;
  right: 0;
  transform: translateY(-50%);
  z-index: 40;
  background: var(--rose-deep);
  color: var(--white);
  font-weight: 700;
  font-size: 0.85rem;
  letter-spacing: 1px;
  padding: 16px 10px;
  border-radius: 12px 0 0 12px;
  box-shadow: -4px 4px 16px rgba(0,0,0,0.2);
  writing-mode: vertical-rl;
  text-orientation: mixed;
  display: flex;
  align-items: center;
  gap: 8px;
  transition: padding 0.2s ease, background 0.2s ease;
}
.side-tab:hover{ background: var(--rose); padding-right: 16px; }
.side-tab.tab-left{
  right: auto;
  left: 0;
  border-radius: 0 12px 12px 0;
  box-shadow: 4px 4px 16px rgba(0,0,0,0.2);
}
.side-tab svg{ width: 16px; height: 16px; }

/* =========================================================
   Footer
========================================================= */
footer{
  background: var(--plum);
  color: var(--blush);
  text-align: center;
  padding: 1.8rem 1.5rem;
  font-size: 0.85rem;
}
footer .footer-phone{ color: var(--gold); font-weight: 700; }
footer a.footer-link{
  display: inline-block;
  margin-top: 0.5rem;
  color: var(--white);
  font-weight: 700;
  text-decoration: underline;
}

/* =========================================================
   Scroll fade-in
========================================================= */
.fade-in{
  opacity: 0;
  transform: translateY(18px);
  transition: opacity 0.7s ease, transform 0.7s ease;
}
.fade-in.is-visible{
  opacity: 1;
  transform: translateY(0);
}

/* =========================================================
   Responsive
========================================================= */
@media (max-width: 560px){
  .header-link{ position: static; transform: none; display: inline-flex; margin-top: 0.6rem; }
  .site-header .logo{ font-size: 1.3rem; }
  .hero{ padding: 3.5rem 1.2rem 4rem; }
  .price-card{ padding: 1.8rem 1.2rem 2.2rem; }
  .price-row .service, .price-row .value{ font-size: 0.88rem; }
  .side-tab{
    padding: 12px 8px;
    font-size: 0.75rem;
  }
  .whatsapp-float{ width: 52px; height: 52px; bottom: 16px; right: 16px; }
}

@media (prefers-reduced-motion: reduce){
  .hero::before, .hero::after{ animation: none; }
  .fade-in{ transition: none; opacity: 1; transform: none; }
}

</style>
</head>
<body>

  <header class="site-header">
    <a href="trabalhos.html" class="header-link">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="16" height="16"><path d="M9 18l6-6-6-6"/></svg>
      Ver trabalhos
    </a>
    <div class="logo">
      Larissa Waszak
      <span>Nail Designer</span>
    </div>
  </header>

  <section class="hero">
    <div class="hero-content">
      <span class="eyebrow-badge">Bem-vinda</span>
      <h1>Unhas que revelam<br>a sua beleza</h1>
      <p class="tagline">Cada atendimento é pensado com <strong>cuidado</strong> e <strong>atenção aos detalhes</strong>, para você sair com as unhas dos seus sonhos.</p>
      <a href="#" data-whatsapp class="btn-primary">
        <svg viewBox="0 0 32 32" fill="currentColor"><path d="M16.001 3C9.371 3 4 8.371 4 15.001c0 2.366.687 4.575 1.875 6.434L4 29l7.766-1.832A11.94 11.94 0 0 0 16.001 27C22.631 27 28 21.629 28 15.001 28 8.371 22.631 3 16.001 3zm6.962 17.27c-.296.836-1.466 1.6-2.02 1.685-.554.085-1.014.13-2.99-.624-2.523-.94-4.151-3.49-4.275-3.654-.124-.165-1.014-1.345-1.014-2.567 0-1.221.64-1.82.866-2.07.226-.249.494-.31.659-.31.165 0 .33.002.473.01.151.008.353-.058.553.422.205.49.696 1.696.757 1.818.062.124.103.27.02.434-.082.165-.124.27-.247.413-.124.144-.26.32-.371.43-.124.123-.253.257-.108.503.144.247.642 1.06 1.378 1.717.946.842 1.745 1.103 1.992 1.227.246.124.39.103.534-.062.144-.165.617-.72.781-.967.165-.246.33-.205.555-.123.225.082 1.43.674 1.677.797.247.124.41.185.472.288.062.103.062.598-.234 1.434z"/></svg>
        Agendar pelo WhatsApp
      </a>
    </div>
  </section>

  <section class="intro fade-in">
    <p>✨ Conheça os trabalhos da Larissa e surpreenda-se com cada detalhe. Aqui, as suas unhas recebem <strong>tratamento especial</strong>, do alongamento à esmaltação, sempre com produtos de qualidade e muito carinho.</p>
  </section>

  <section class="pricing" id="valores">
    <div class="section-heading fade-in">
      <span class="pill">Valores</span>
      <h2>Unhas tradicionais</h2>
      <svg class="brush-underline" viewBox="0 0 200 20" xmlns="http://www.w3.org/2000/svg">
        <path d="M2 14 C40 2, 80 22, 120 10 C150 2, 170 18, 198 8"/>
      </svg>
    </div>

    <div class="price-card fade-in">
      <div class="price-row">
        <span class="service">Mão tradicional</span>
        <span class="value">R$ 30,00</span>
      </div>
      <div class="price-row">
        <span class="service">Pé tradicional</span>
        <span class="value">R$ 40,00</span>
      </div>
      <div class="price-row">
        <span class="service">Mão + Pé</span>
        <span class="value">R$ 60,00</span>
      </div>
      <div class="price-row">
        <span class="service">Esmaltação em gel mão</span>
        <span class="value">R$ 60,00</span>
      </div>
      <div class="price-row">
        <span class="service">Esmaltação em gel pé</span>
        <span class="value">R$ 70,00</span>
      </div>
      <div class="price-row">
        <span class="service">Esmaltação em gel pé + mão</span>
        <span class="value">R$ 120,00</span>
      </div>
      <div class="price-row">
        <span class="service">Blindagem</span>
        <span class="value">R$ 80,00</span>
      </div>
      <div class="price-row">
        <span class="service">Banho de gel</span>
        <span class="value">R$ 100,00</span>
      </div>
      <div class="price-row">
        <span class="service">Manutenção banho de gel</span>
        <span class="value">R$ 80,00</span>
      </div>
    </div>

    <p class="price-quote fade-in">Suas unhas merecem esse cuidado especial!</p>
    <p class="price-signature fade-in">Larissa Waszak<span>Nail designer</span></p>
  </section>

  <section class="final-cta fade-in">
    <h2>Pronta para cuidar das suas unhas?</h2>
    <p>Fale agora mesmo com a <strong>Larissa</strong> e agende o seu horário. Atendimento rápido, direto pelo WhatsApp.</p>
    <div class="phone">📱 <strong>+55 51 8119-1766</strong></div>
    <br>
    <a href="#" data-whatsapp class="btn-whatsapp-inline">
      <svg viewBox="0 0 32 32" fill="currentColor"><path d="M16.001 3C9.371 3 4 8.371 4 15.001c0 2.366.687 4.575 1.875 6.434L4 29l7.766-1.832A11.94 11.94 0 0 0 16.001 27C22.631 27 28 21.629 28 15.001 28 8.371 22.631 3 16.001 3zm6.962 17.27c-.296.836-1.466 1.6-2.02 1.685-.554.085-1.014.13-2.99-.624-2.523-.94-4.151-3.49-4.275-3.654-.124-.165-1.014-1.345-1.014-2.567 0-1.221.64-1.82.866-2.07.226-.249.494-.31.659-.31.165 0 .33.002.473.01.151.008.353-.058.553.422.205.49.696 1.696.757 1.818.062.124.103.27.02.434-.082.165-.124.27-.247.413-.124.144-.26.32-.371.43-.124.123-.253.257-.108.503.144.247.642 1.06 1.378 1.717.946.842 1.745 1.103 1.992 1.227.246.124.39.103.534-.062.144-.165.617-.72.781-.967.165-.246.33-.205.555-.123.225.082 1.43.674 1.677.797.247.124.41.185.472.288.062.103.062.598-.234 1.434z"/></svg>
      Falar com a Larissa
    </a>
  </section>

  <footer>
    <p>© 2026 Larissa Waszak — Nail Designer. Todos os direitos reservados.</p>
    <p>Contato: <span class="footer-phone">+55 51 8119-1766</span></p>
    <a href="trabalhos.html" class="footer-link">Ver trabalhos realizados →</a>
  </footer>

  <a href="#" data-whatsapp class="whatsapp-float" aria-label="Falar no WhatsApp">
    <svg viewBox="0 0 32 32" fill="currentColor"><path d="M16.001 3C9.371 3 4 8.371 4 15.001c0 2.366.687 4.575 1.875 6.434L4 29l7.766-1.832A11.94 11.94 0 0 0 16.001 27C22.631 27 28 21.629 28 15.001 28 8.371 22.631 3 16.001 3zm6.962 17.27c-.296.836-1.466 1.6-2.02 1.685-.554.085-1.014.13-2.99-.624-2.523-.94-4.151-3.49-4.275-3.654-.124-.165-1.014-1.345-1.014-2.567 0-1.221.64-1.82.866-2.07.226-.249.494-.31.659-.31.165 0 .33.002.473.01.151.008.353-.058.553.422.205.49.696 1.696.757 1.818.062.124.103.27.02.434-.082.165-.124.27-.247.413-.124.144-.26.32-.371.43-.124.123-.253.257-.108.503.144.247.642 1.06 1.378 1.717.946.842 1.745 1.103 1.992 1.227.246.124.39.103.534-.062.144-.165.617-.72.781-.967.165-.246.33-.205.555-.123.225.082 1.43.674 1.677.797.247.124.41.185.472.288.062.103.062.598-.234 1.434z"/></svg>
    <span>Fale comigo</span>
  </a>

  <a href="trabalhos.html" class="side-tab">
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M13 6l6 6-6 6"/></svg>
    Ver trabalhos
  </a>

  <script>
// =========================================================
// Larissa Waszak — Nail Designer
// WhatsApp number + pre-filled message
// =========================================================
const WHATSAPP_NUMBER = "555181191766"; // +55 51 8119-1766
const WHATSAPP_MESSAGE = "Olá Larissa! Vim pelo site e gostaria de agendar um horário para fazer minhas unhas. 💅✨";

function buildWhatsappLink(){
  return `https://wa.me/${WHATSAPP_NUMBER}?text=${encodeURIComponent(WHATSAPP_MESSAGE)}`;
}

document.addEventListener("DOMContentLoaded", () => {
  // Set every WhatsApp link on the page with the correct number + message
  document.querySelectorAll("[data-whatsapp]").forEach((el) => {
    el.href = buildWhatsappLink();
    el.target = "_blank";
    el.rel = "noopener";
  });

  // Gentle scroll reveal
  const revealEls = document.querySelectorAll(".fade-in");
  if ("IntersectionObserver" in window && revealEls.length){
    const observer = new IntersectionObserver((entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting){
          entry.target.classList.add("is-visible");
          observer.unobserve(entry.target);
        }
      });
    }, { threshold: 0.15 });
    revealEls.forEach((el) => observer.observe(el));
  } else {
    revealEls.forEach((el) => el.classList.add("is-visible"));
  }
});

</script>
</body>
</html>
